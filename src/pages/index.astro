---
// src/pages/index.astro — homepage. Kept as a self-contained document (not the
// shared Layout) so the SEO baseline tags live directly in this file, which is
// what src/__tests__/seo.test.js (CHECK_161 regression) asserts against.
import "../styles/global.css";
import { Landing } from "../components/Landing";

const site = "https://bppvcoach.com";
const title = "Unspin — Guided positioning for your prescribed Epley maneuver";
const description =
  "Sensor-guided head-positioning companion for adults previously diagnosed with posterior-canal BPPV. Educational only — not a diagnostic tool.";
// Canonical MUST match the served URL incl. trailing slash (trailingSlash:
// 'always' in astro.config.mjs).
const canonical = `${site}/`;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, viewport-fit=cover"
    />
    <meta name="theme-color" content="#0f3b46" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Unspin — Guided Epley positioning" />
    <meta
      property="og:description"
      content="Real-time head positioning feedback for a previously prescribed Epley maneuver."
    />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Unspin" />

    <!-- Twitter card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="Unspin — Guided Epley positioning" />
    <meta
      name="twitter:description"
      content="Real-time head positioning feedback for a previously prescribed Epley maneuver."
    />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
    />

    <!-- JSON-LD structured data: Organization + WebSite -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Organization",
          "@id": "https://bppvcoach.com/#organization",
          "name": "Unspin",
          "url": "https://bppvcoach.com/",
        },
        {
          "@type": "WebSite",
          "@id": "https://bppvcoach.com/#website",
          "url": "https://bppvcoach.com/",
          "name": "Unspin",
          "publisher": { "@id": "https://bppvcoach.com/#organization" },
        },
      ],
    })} />
  </head>
  <body>
    <Landing />
  </body>
</html>
